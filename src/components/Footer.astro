---
// Social icons come from the design-system sprite, synced to /vendor/icons.svg.
// hrefs are placeholders until real profile URLs are provided (tracked in backlog).
const year = 2026;
const socials = [
  { id: 'github-icon', label: 'GitHub', href: '#' },
  { id: 'x-icon', label: 'X', href: '#' },
];
---

<footer class="footer">
  <div class="footer-inner">
    <span class="copy">© {year} EarlBear, Inc.</span>
    <div class="socials">
      {
        socials.map((s) => (
          <a href={s.href} aria-label={s.label}>
            <svg width="18" height="18" aria-hidden="true">
              <use href={`/vendor/icons.svg#${s.id}`} />
            </svg>
          </a>
        ))
      }
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border-subtle);
    background: var(--color-canvas);
    padding: var(--space-8) var(--space-6);
  }
  .footer-inner {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
  }
  .socials {
    display: flex;
    gap: var(--space-4);
  }
  .socials a {
    color: var(--color-text-muted);
    border: none;
    display: inline-flex;
    transition: color var(--dur-fast) var(--ease-standard);
  }
  .socials a:hover {
    color: var(--color-text-accent);
  }
  .socials svg {
    fill: currentColor;
  }
</style>
