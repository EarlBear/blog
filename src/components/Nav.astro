---
import EarlMark from './EarlMark.astro';

interface Props {
  // True on the internal (access-gated) build — shows an "internal" marker so
  // there is never ambiguity about which site this is.
  internal?: boolean;
}
const { internal = false } = Astro.props;
// On localhost only, the internal badge becomes a toggle that PREVIEWS the
// external view (hides audience:internal post cards, swaps the theme + label).
// It is a preview, not the real external build — that is `npm run build:external`
// (dev shows every audience regardless of PUBLIC_AUDIENCE). Never rendered in prod.
const devToggle = import.meta.env.DEV && internal;
// The Drafts toggle is dev-only too, but independent of audience — drafts exist on
// both the internal and external working sets, so it shows on any localhost build.
const devDrafts = import.meta.env.DEV;

const links = [
  { href: '/', label: 'Posts' },
  { href: '/tags/', label: 'Tags' },
  { href: '/authors/', label: 'Authors' },
  { href: '/about/', label: 'About' },
  { href: '/rss.xml', label: 'RSS' },
  // Repo Map is an INTERNAL-only reference page (src/pages/repo-map.astro
  // self-guards to 404 on the external build). Only link it on the internal
  // build so the external nav never advertises it — one more layer alongside
  // the page guard and the sitemap filter. See docs/features/audience-split.md.
  ...(internal ? [{ href: '/repo-map/', label: 'Repo Map' }] : []),
];
---

<nav class="nav">
  <a class="brand" href="/" aria-label={internal ? 'EarlBear internal blog home' : 'EarlBear blog home'}>
    <span class="mark"><EarlMark size={24} /></span>
    <span class="brand-text">EarlBear</span>
    <span class="brand-sub">blog</span>
  </a>
  {internal && !devToggle && <span class="internal-badge">internal</span>}
  {devToggle && (
    <button
      type="button"
      class="internal-badge internal-badge--toggle"
      data-audience-toggle
      title="Preview the external view (dev only). This hides internal-only posts and swaps the theme — it is a preview, not the real external build (npm run build:external)."
      aria-pressed="false"
    >
      <span data-toggle-label>internal</span>
    </button>
  )}
  {devDrafts && (
    <button
      type="button"
      class="drafts-badge drafts-badge--toggle"
      data-drafts-toggle
      title="Show or hide draft post cards (dev only). Drafts are always shown by default in dev; toggle off to preview the list as it will read once they publish. Never affects the real build."
      aria-pressed="true"
    >
      <span data-drafts-label>drafts on</span>
    </button>
  )}
  <div class="links">
    {links.map((l) => <a href={l.href}>{l.label}</a>)}
  </div>
  {internal && (
    <div class="usermenu">
      {/* Email filled in client-side from CF Access get-identity (below); hidden until known. */}
      <span class="user-email" data-user-email hidden></span>
      {/* Standard EarlBear Sign-out: clears the CF Access session on this host. Matches the shared
          @earlbear/ui UserMenu / gallery pattern. See earlbear-domain/docs/internal-nav-design.md. */}
      <a
        class="signout"
        href="/cdn-cgi/access/logout"
        title="Sign out of EarlBear. This clears your EarlBear (Cloudflare Access) session; your Google account stays signed in on this browser (sign out of Google directly for a full logout)."
      >Sign out</a>
    </div>
  )}
</nav>

{
  /* DEV-ONLY: the internal badge toggles an external PREVIEW. Sets data-preview on
     <html> (CSS hides internal cards + swaps the theme), persists in localStorage.
     import.meta.env.DEV is statically false in any production build, so this whole
     block is tree-shaken out — it never ships. */
  devToggle && (
    <script is:inline>
      (() => {
        const KEY = 'eb-preview-audience';
        const root = document.documentElement;
        const btn = document.querySelector('[data-audience-toggle]');
        const label = btn && btn.querySelector('[data-toggle-label]');
        function apply(preview) {
          if (preview === 'external') root.setAttribute('data-preview', 'external');
          else root.removeAttribute('data-preview');
          if (btn) btn.setAttribute('aria-pressed', preview === 'external' ? 'true' : 'false');
          if (label) label.textContent = preview === 'external' ? 'external' : 'internal';
        }
        apply(localStorage.getItem(KEY) || 'internal');
        if (btn)
          btn.addEventListener('click', () => {
            const next = root.getAttribute('data-preview') === 'external' ? 'internal' : 'external';
            localStorage.setItem(KEY, next);
            apply(next);
          });
      })();
    </script>
  )
}

{
  /* DEV-ONLY: the Drafts pill toggles hiding draft post cards. Sets data-drafts="hide"
     on <html> (CSS hides .card[data-post-draft]), persists in localStorage. Default is
     "show" (drafts visible), matching dev today. import.meta.env.DEV is statically false
     in any production build, so this block is tree-shaken out — it never ships. */
  devDrafts && (
    <script is:inline>
      (() => {
        const KEY = 'eb-drafts-visibility';
        const root = document.documentElement;
        const btn = document.querySelector('[data-drafts-toggle]');
        const label = btn && btn.querySelector('[data-drafts-label]');
        function apply(state) {
          if (state === 'hide') root.setAttribute('data-drafts', 'hide');
          else root.removeAttribute('data-drafts');
          if (btn) btn.setAttribute('aria-pressed', state === 'hide' ? 'false' : 'true');
          if (label) label.textContent = state === 'hide' ? 'drafts off' : 'drafts on';
        }
        apply(localStorage.getItem(KEY) || 'show');
        if (btn)
          btn.addEventListener('click', () => {
            const next = root.getAttribute('data-drafts') === 'hide' ? 'show' : 'hide';
            localStorage.setItem(KEY, next);
            apply(next);
          });
      })();
    </script>
  )
}

{
  /* Internal-only: show the signed-in email. This is the ONLY client JS the internal blog ships,
     and it runs solely on the CF-Access-gated build. The email is DISPLAY-ONLY (never used for authz).
     get-identity is reachable only past the gate, so it's absent/failing on the public build. */
  internal && (
    <script is:inline>
      fetch('/cdn-cgi/access/get-identity', { credentials: 'include' })
        .then((r) => (r.ok ? r.json() : null))
        .then((d) => {
          const email = d && (d.email || (d.identity && d.identity.email));
          const el = document.querySelector('[data-user-email]');
          if (email && el) { el.textContent = email; el.hidden = false; }
        })
        .catch(() => {});
    </script>
  )
}

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(251, 249, 245, 0.92);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border-subtle);
    height: 64px;
    padding: 0 var(--space-6);
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }
  .brand {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
    text-decoration: none;
    border: none;
  }
  /* Signed-in email + Sign-out (internal build only) — mirrors the shared @earlbear/ui UserMenu.
     Sits just right of the nav links (which carry the margin-left:auto), separated by a comfortable
     gap so the links + sign-out read as one right-aligned cluster rather than drifting apart. */
  .usermenu {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding-left: var(--space-2);
  }
  .user-email {
    font-size: var(--fs-xs);
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
  }
  .signout {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-sans);
    font-size: var(--fs-xs);
    font-weight: var(--fw-semibold);
    padding: 5px 12px;
    border-radius: 9999px;
    text-decoration: none;
    border: 1px solid var(--color-border-subtle);
    color: var(--color-text-secondary);
    background: var(--color-surface);
    transition: all 150ms;
  }
  .signout:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .mark {
    color: var(--color-accent);
    display: inline-flex;
    align-self: center;
  }
  .brand-text {
    font-size: var(--fs-lg);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--ls-tight);
    color: var(--color-text);
  }
  .brand-sub {
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    font-weight: var(--fw-regular);
  }
  .internal-badge {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-accent);
    background: var(--color-accent-soft);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-pill);
    padding: 2px 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1;
  }
  /* Dev-only preview toggle: same pill, but interactive. */
  .internal-badge--toggle {
    cursor: pointer;
    transition: filter 0.12s ease;
  }
  .internal-badge--toggle:hover {
    filter: brightness(0.96);
  }
  .internal-badge--toggle::after {
    content: ' ⇄';
    opacity: 0.6;
  }
  /* Dev-only Drafts toggle: a neutral (muted) sibling pill beside the audience toggle,
     so it reads as a secondary control rather than competing with the accent badge. */
  .drafts-badge {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-text-secondary);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    padding: 2px 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1;
    cursor: pointer;
    transition: filter 0.12s ease, border-color 0.12s ease, color 0.12s ease;
  }
  .drafts-badge--toggle:hover {
    border-color: var(--color-text-secondary);
    color: var(--color-text);
  }
  /* When drafts are hidden (aria-pressed=false), dim the pill to signal the "off" state. */
  .drafts-badge--toggle[aria-pressed='false'] {
    opacity: 0.62;
  }
  /* The nav links carry the single margin-left:auto — this pushes the links (and,
     on the internal build, the sign-out cluster that follows) to the right, with
     the brand/badge alone on the left. Exactly one auto margin, so the groups
     don't fight over the free space. */
  .links {
    margin-left: auto;
    display: flex;
    gap: var(--space-5);
  }
  .links a {
    font-size: var(--fs-sm);
    font-weight: var(--fw-medium);
    color: var(--color-text-secondary);
    text-decoration: none;
    border: none;
    transition: color var(--dur-fast) var(--ease-standard);
  }
  .links a:hover {
    color: var(--color-text-accent);
  }
  @media (max-width: 480px) {
    .brand-sub {
      display: none;
    }
    .links {
      gap: var(--space-4);
      /* Belt-and-suspenders: at phone widths the links stay on one line but may
         scroll within their own row rather than pushing the page — so the nav can
         never cause a horizontal page scroll, even when the internal build adds the
         live sign-out cluster (rendered client-side past the CF Access gate, so it
         isn't visible to a local build/audit). Guards the ≤390px overflow the
         frontend-audit flagged. See docs/tasks/ [audit-finding]. */
      min-width: 0;
      overflow-x: auto;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }
    .links::-webkit-scrollbar {
      display: none;
    }
  }
</style>
