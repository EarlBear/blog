---
import { resolveAuthors } from '../lib/authors';

interface Props {
  authorIds: string[];
  linked?: boolean; // link each name to /authors/<id>/ (default true)
}
const { authorIds, linked = true } = Astro.props;
const authors = await resolveAuthors(authorIds);
---

{
  authors.length > 0 && (
    <span class="byline">
      By{' '}
      {authors.map((author, i) => (
        <>
          {linked ? (
            <a href={`/authors/${author.id}/`}>{author.data.name}</a>
          ) : (
            <span>{author.data.name}</span>
          )}
          {i < authors.length - 2 ? ', ' : i === authors.length - 2 ? ' and ' : ''}
        </>
      ))}
    </span>
  )
}

<style>
  .byline {
    color: var(--color-text-muted);
  }
  .byline a {
    color: var(--color-text-secondary);
    border: none;
    text-decoration: none;
  }
  .byline a:hover {
    color: var(--color-text-accent);
  }
</style>
