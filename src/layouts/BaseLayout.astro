---
// Design tokens, vendored from EarlBear/design-system (see .sync-source.json).
// Re-pull with `npm run sync-assets`.
import '../styles/tokens.css';
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import DiagramFullscreen from '../components/DiagramFullscreen.astro';
import CommentLayer from '../components/CommentLayer.astro';
import { isInternalBuild } from '../lib/posts';

// Which site this build is: the internal (access-gated) site gets a distinct
// accent and an "internal" chrome marker so there is never any doubt which
// blog you are looking at. Chosen at build time by PUBLIC_AUDIENCE.
const internal = isInternalBuild();

interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
  publishedTime?: Date;
}

const {
  title,
  description = 'Engineering notes and product writing from EarlBear.',
  ogType = 'website',
  publishedTime,
} = Astro.props;

const siteName = internal ? 'EarlBear blog (internal)' : 'EarlBear blog';
const fullTitle = title === siteName ? title : `${title} · ${siteName}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/favicon.svg', Astro.site);
---

<!doctype html>
<html lang="en" data-audience={internal ? 'internal' : 'external'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {internal && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />

    {/* Internal-site theme: re-tint the accent to a distinct teal so the
        internal blog is unmistakable at a glance. Semantic-token override only —
        references design-system primitives, no raw hex, no dark mode. Scoped to
        [data-audience="internal"] so it is inert on the external build. */}
    {internal && (
      <style is:global>
        {`
          html[data-audience='internal'] {
            --color-accent:        var(--eb-info);        /* teal 500 */
            --color-accent-hover:  #235d66;                /* teal 600 */
            --color-accent-press:  #1c4a52;                /* teal 700 */
            --color-accent-soft:   var(--eb-info-bg);
            --color-border-focus:  var(--eb-info);
            --color-text-accent:   #235d66;
          }
        `}
      </style>
    )}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap"
    />

    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteName}
      href={new URL('/rss.xml', Astro.site)}
    />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    {
      publishedTime && (
        <meta
          property="article:published_time"
          content={publishedTime.toISOString()}
        />
      )
    }
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <Nav internal={internal} />
    <main>
      <slot />
    </main>
    <Footer />
    <DiagramFullscreen />
    {/* Comment layer — internal build only (CF Access gated + RLS enforced). The external
        build never renders it, so the public site ships no comment UI. */}
    {internal && <CommentLayer />}
  </body>
</html>
