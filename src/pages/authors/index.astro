---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAuthorsWithCounts } from '../../lib/authors';

const authors = await getAuthorsWithCounts();
---

<BaseLayout
  title="Authors"
  description="The people and bears writing on the EarlBear blog."
>
  <div class="container">
    <header class="page-head">
      <p class="eyebrow">Meet the</p>
      <h1>Authors</h1>
    </header>

    {
      authors.length === 0 ? (
        <p class="empty">No authors yet.</p>
      ) : (
        <ul class="author-grid">
          {authors.map(({ author, count }) => (
            <li class="author-card">
              <a href={`/authors/${author.id}/`} class="card-link">
                {author.data.avatar && (
                  <img
                    class="avatar"
                    src={author.data.avatar}
                    alt=""
                    width="48"
                    height="48"
                  />
                )}
                <div class="who">
                  <span class="name">{author.data.name}</span>
                  {author.data.role && (
                    <span class="role">{author.data.role}</span>
                  )}
                  <span class="count num">
                    {count} post{count === 1 ? '' : 's'}
                  </span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</BaseLayout>

<style>
  .page-head {
    margin-bottom: var(--space-6);
  }
  .page-head .eyebrow {
    color: var(--color-accent);
  }
  .page-head h1 {
    margin-top: var(--space-2);
  }
  .author-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-4);
  }
  .card-link {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    text-decoration: none;
    border-color: var(--color-border-subtle);
    transition: box-shadow var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }
  .card-link:hover {
    box-shadow: var(--shadow-sm);
    border-color: var(--color-border);
  }
  .avatar {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-pill);
    background: var(--color-accent-soft);
    padding: 6px;
    color: var(--color-accent);
    flex-shrink: 0;
  }
  .who {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .name {
    font-weight: var(--fw-semibold);
    color: var(--color-text);
  }
  .role {
    font-size: var(--fs-sm);
    color: var(--color-text-secondary);
  }
  .count {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    margin-top: 2px;
  }
  .empty {
    color: var(--color-text-muted);
  }
</style>
