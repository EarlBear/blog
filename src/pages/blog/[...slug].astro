---
import { render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { getPublishedPosts, readingTime } from '../../lib/posts';
import { postCommit } from '../../lib/post-commit';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
// The git SHA that last touched THIS post's source — the range-anchor version pin (Axis B4).
// Changes only when the post file changes, not on every repo commit, so it isn't a noisy signal.
const commit = postCommit(post.id, post.filePath);
---

<PostLayout {...post.data} readingTime={readingTime(post.body)} postCommit={commit}>
  <Content />
</PostLayout>
