{
  "name": "earlbear-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync-assets": "node scripts/sync-ui-assets.mjs",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "npm run build && gh-pages -d dist --dotfiles --nojekyll -m \"Deploy blog\"",
    "tasks-check": "python3 .claude/hooks/check-task-files.py --check",
    "posts-check": "python3 .claude/hooks/check-posts.py --check",
    "diagrams-check": "python3 .claude/hooks/check-diagrams.py --check",
    "visuals-check": "python3 .claude/hooks/check-visual-density.py --check",
    "catalog-check": "python3 .claude/hooks/check-diagram-catalog.py --check",
    "features:check": "python3 scripts/features_check.py",
    "features:seed": "python3 scripts/features_check.py --seed",
    "regen-favicon": "node scripts/gen-favicon.mjs",
    "bench:diagram": "node --experimental-websocket scripts/diagram-bench.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/rss": "^4.0.11",
    "@astrojs/sitemap": "^3.2.1",
    "astro": "^5.1.1"
  },
  "devDependencies": {
    "gh-pages": "^6.2.0"
  }
}
