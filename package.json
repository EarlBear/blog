{
  "name": "earlbear-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync-assets": "node scripts/sync-ui-assets.mjs",
    "dev": "astro dev",
    "build": "astro build",
    "build:external": "PUBLIC_AUDIENCE=external astro build",
    "build:internal": "PUBLIC_AUDIENCE=internal astro build",
    "preview": "astro preview",
    "audience-check": "python3 .claude/hooks/check-audience.py --check-dist dist",
    "secrets-check": "python3 .claude/hooks/check-env-encrypted.py --check",
    "anchor-ids-check": "python3 .claude/hooks/check-anchor-ids.py --check dist",
    "deploy": "PUBLIC_AUDIENCE=external python3 .claude/hooks/check-audience.py --assert-target external && npm run build:external && npm run audience-check && gh-pages -d dist --dotfiles --nojekyll -m \"Deploy blog\"",
    "deploy:internal": "PUBLIC_AUDIENCE=internal python3 .claude/hooks/check-audience.py --assert-target internal && npm run build:internal && python3 .claude/hooks/check-audience.py --check-dist dist --audience internal && rm -f dist/CNAME && ./node_modules/.bin/dotenvx run --quiet -- ./node_modules/.bin/wrangler pages deploy dist --project-name earlbear-blog-internal --branch main --commit-dirty=true",
    "key-backup": "scripts/lastpass-key.sh backup",
    "key-restore": "scripts/lastpass-key.sh restore",
    "key-status": "scripts/lastpass-key.sh status",
    "tasks-check": "python3 .claude/hooks/check-task-files.py --check",
    "posts-check": "python3 .claude/hooks/check-posts.py --check",
    "diagrams-check": "python3 .claude/hooks/check-diagrams.py --check",
    "visuals-check": "python3 .claude/hooks/check-visual-density.py --check",
    "catalog-check": "python3 .claude/hooks/check-diagram-catalog.py --check",
    "expects-check": "python3 .claude/hooks/check-visual-expectations.py --check",
    "audience-fit-check": "python3 .claude/hooks/check-audience-fit.py --check",
    "secret-sauce-check": "python3 .claude/hooks/check-secret-sauce.py --check",
    "features:check": "python3 scripts/features_check.py",
    "features:seed": "python3 scripts/features_check.py --seed",
    "regen-favicon": "node scripts/gen-favicon.mjs",
    "bench:diagram": "node --experimental-websocket scripts/diagram-bench.mjs",
    "reconcile-comments": "node scripts/reconcile-comments.mjs",
    "test:reconcile": "npm --prefix ../earlbear-comments test",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/rss": "^4.0.11",
    "@astrojs/sitemap": "^3.2.1",
    "@earlbear/auth-client": "file:../earlbear-packages/packages/auth-client",
    "@earlbear/auth-server": "file:../earlbear-packages/packages/auth-server",
    "@earlbear/comments": "file:../earlbear-comments",
    "@earlbear/ui": "file:../earlbear-design-system",
    "@supabase/supabase-js": "^2.47.10",
    "astro": "^5.1.1"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.75.1",
    "@playwright/test": "^1.61.1",
    "gh-pages": "^6.2.0",
    "wrangler": "^4.84.0"
  }
}
