# @earlbear-scoped packages (auth-server, auth-client) install from GitHub Packages.
# The auth token is NOT here (never commit one) — it comes from your ~/.npmrc:
#   @earlbear:registry=https://npm.pkg.github.com
#   //npm.pkg.github.com/:_authToken=<a GitHub PAT (classic) with read:packages>
# @earlbear/comments and @earlbear/ui stay on file: links (separate repos, not in the monorepo).
@earlbear:registry=https://npm.pkg.github.com
