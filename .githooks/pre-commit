#!/bin/sh
# Block commits that contain secrets.
# Install once with: make install-hooks  (sets core.hooksPath to .githooks)

if ! command -v gitleaks >/dev/null 2>&1; then
    echo ""
    echo "ERROR: gitleaks is not installed."
    echo "Install it with: brew install gitleaks"
    echo ""
    echo "Commits are blocked until gitleaks is available."
    exit 1
fi

echo "Scanning staged changes for secrets..."
gitleaks protect --staged --verbose
if [ $? -ne 0 ]; then
    echo ""
    echo "ERROR: Secret found in staged changes. Commit blocked."
    echo "If this is a false positive, add it to .gitleaks.toml allowlist."
    exit 1
fi

# Structural dotenvx guard: gitleaks only catches secret-SHAPED values; this fails a commit
# if a staged .env* file has ANY plaintext value (must be `encrypted:`, blank, or the public
# key). Catches a forgotten `make encrypt` after `make decrypt`, or a plaintext config value.
if command -v python3 >/dev/null 2>&1; then
    python3 .claude/hooks/check-env-encrypted.py --staged || exit 1
fi
