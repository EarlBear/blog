{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh .githooks/repo-setup-guard.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/check-blog-dev-env.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/check-posts.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/check-audience.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/check-diagrams.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/check-visual-density.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/check-diagram-catalog.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/check-visual-expectations.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/check-post-spacing.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/check-audience-fit.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/check-secret-sauce.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/check-reader-flow.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/check-env-encrypted.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "MARKER=/tmp/earlbear-plugins-checked-${PPID}; [ -f \"$MARKER\" ] && exit 0; touch \"$MARKER\"; bash /Users/omareid/Workspace/git-earlbear/earlbear-claude-plugin-marketplace/scripts/check-plugins.sh task-management-manager decision-tracking-manager"
          }
        ]
      }
    ]
  },
  "plansDirectory": ".claude/plans",
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  }
}
